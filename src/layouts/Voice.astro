---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

const subNav = [
  { href: '/voice/use-cases/', label: 'use cases' },
  { href: '/voice/talk/', label: 'talk to us' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') + '/';
---

<Base title={`${title} — WaveKat`} description={description}>
  <div class="max-w-3xl mx-auto px-6 py-12">

    <Header active="voice" />

    <!-- Sub-nav -->
    <nav class="flex flex-wrap items-center gap-x-4 gap-y-2 mb-12 text-xs">
      <a href="/voice/" class="font-bold" style="color: #ff6d00">voice</a>
      <span class="text-gray-300 dark:text-white/10">/</span>
      {subNav.map((item) => {
        const active = currentPath === item.href;
        return (
          <a
            href={item.href}
            class={
              active
                ? 'text-gray-700 dark:text-gray-200'
                : 'text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 transition-colors'
            }
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <slot />

    <div class="mt-20">
      <Footer />
    </div>

  </div>
</Base>
