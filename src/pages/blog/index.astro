---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="Blog — WaveKat" description="Engineering notes, announcements, and deep-dives from the WaveKat team.">
  <div class="max-w-3xl mx-auto px-6 py-12">

    <Header active="blog" />

    <!-- Blog listing -->
    <section class="mb-20">
      <h1 class="text-2xl font-bold leading-snug mb-3 text-gray-900 dark:text-white">Blog</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed mb-10">
        Engineering notes, announcements, and deep-dives from the WaveKat team.
      </p>

      {posts.length === 0 ? (
        <p class="text-sm text-gray-400 dark:text-gray-600">No posts yet. Check back soon.</p>
      ) : (
        <div class="grid gap-3">
          {posts.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              tags={post.data.tags}
              slug={post.id}
            />
          ))}
        </div>
      )}
    </section>

    <Footer />

  </div>
</Base>
